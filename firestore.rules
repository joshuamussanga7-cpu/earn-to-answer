rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if isAdmin() || isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.role == 'user' && request.resource.data.balance == 0;

      // Profile updates
      allow update: if isAdmin()
                    || (isOwner(userId)
                        && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['balance', 'role', 'isBanned', 'referralEarnings', 'referralCount'])
                        && resource.data.isBanned == false);

      // Controlled updates for Rewards & Promo Codes
      allow update: if isOwner(userId)
                    && resource.data.isBanned == false
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
                        'balance', 'totalXP', 'totalVideosWatched', 'videoTasksCompleted',
                        'totalTasksDone', 'lastCheckIn', 'lastWheelSpin', 'checkInStreak',
                        'lastSurveyDate', 'completedSocialTasks', 'usedPromos', 'fcmToken', 'walletAddress'
                    ])
                    && (request.resource.data.balance - resource.data.balance) <= 5.0;

      match /transactions/{txId} {
        allow read: if isAdmin() || isOwner(userId);
        allow create: if isOwner(userId);
      }

      match /notifications/{notifId} {
        allow read: if isOwner(userId);
        allow update: if isOwner(userId);
        allow delete: if isOwner(userId);
      }
    }

    match /payouts/{payoutId} {
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow read: if isSignedIn();
      allow update: if isAdmin();
    }

    match /promo_codes/{code} {
      allow read: if isSignedIn();
    }

    match /custom_tasks/{taskId} {
      allow read: if isSignedIn();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow create: if isAdmin();
    }
  }
}